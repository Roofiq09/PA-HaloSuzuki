        WebAutomation.ExecuteJavascript BrowserInstance: $fx'=Edge' Javascript: $fx'function ExecuteScript() {

    let raw = \'${JanjiSelesai}\';

    console.log("RAW JAM:", raw);

    if (raw.includes(".")) {
        let excelFloat = parseFloat(raw);
        let totalMinutes = Math.round(excelFloat * 24 * 60);
        let hh = Math.floor(totalMinutes / 60);
        let mm = totalMinutes % 60;
        raw = ("0" + hh).slice(-2) + ":" + ("0" + mm).slice(-2);
    }

    let value = raw.trim();

    if (!value.includes(":")) {
        console.log("FORMAT SALAH:", value);
        return;
    }

    let parts = value.split(":");
    let targetHour = parseInt(parts[0]);
    let targetMinute = parseInt(parts[1]);

    let hourBtn = document.querySelector(\'[data-test="hours-toggle-overlay-btn-0"]\');
    let minBtn  = document.querySelector(\'[data-test="minutes-toggle-overlay-btn-0"]\');

    if (!hourBtn || !minBtn) {
        console.log("TIME PICKER NOT OPEN");
        return;
    }

    function wait(ms) {
        return new Promise(r => setTimeout(r, ms));
    }

    // 🔥 PENTING: RETURN ASYNC FUNCTION
    return (async () => {

        let currentHour = parseInt(hourBtn.textContent.trim());
        let diffH = targetHour - currentHour;

        for (let i = 0; i < Math.abs(diffH); i++) {
            let inc = document.querySelector(\'[data-test="hours-time-inc-btn-0"]\');
            let dec = document.querySelector(\'[data-test="hours-time-dec-btn-0"]\');

            if (diffH > 0) inc.click();
            else dec.click();

            await wait(120);
        }

        await wait(200);

        let currentMinute = parseInt(minBtn.textContent.trim());
        let diffM = targetMinute - currentMinute;

        for (let i = 0; i < Math.abs(diffM); i++) {
            let inc = document.querySelector(\'[data-test="minutes-time-inc-btn-0"]\');
            let dec = document.querySelector(\'[data-test="minutes-time-dec-btn-0"]\');

            if (diffM > 0) inc.click();
            else dec.click();

            await wait(80);
        }

        await wait(5000);

        console.log("TIME SET SUCCESS:", value);

        return value; // biar PAD nunggu sampai sini

    })();
