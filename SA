        WebAutomation.ExecuteJavascript BrowserInstance: $fx'=Edge' Javascript: $fx'function ExecuteScript() {

    function wait(ms) {
        return new Promise(res => setTimeout(res, ms));
    }

    async function waitUntilEnabled(el, timeout = 5000) {
        let start = Date.now();

        while (Date.now() - start < timeout) {

            if (!el.disabled && !el.hasAttribute("disabled")) {
                return true;
            }

            // paksa lagi kalau balik disable
            el.removeAttribute("disabled");
            el.disabled = false;
            el.readOnly = false;

            await wait(200);
        }

        return false;
    }

    return (async () => {

        try {

            let selectors = [
                "input[name=\'frame_number\']",
                "input[name=\'year\']"
            ];

            for (let sel of selectors) {

                let el = document.querySelector(sel);

                if (!el) {
                    return "NOT_FOUND_" + sel;
                }

                // paksa enable
                el.removeAttribute("disabled");
                el.disabled = false;
                el.readOnly = false;

                // 🔥 tunggu sampai benar2 aktif
                let ok = await waitUntilEnabled(el, 5000);

                if (!ok) {
                    return "FAILED_ENABLE_" + sel;
                }
            }

            return "SUCCESS_ENABLED";

        } catch (err) {
            return "ERROR_" + err.message;
        }

    })();
